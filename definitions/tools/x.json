{
  "name": "x",
  "type": "service",
  "description": "X as a tool (OAuth 2.0 user token)",
  "auth": {
    "credentials": [
      {
        "source": {"field": "access_token"},
        "inject": {"type": "env", "env_var": "X_ACCESS_TOKEN"}
      },
      {
        "source": {"field": "user_id"},
        "inject": {"type": "env", "env_var": "X_USER_ID"}
      }
    ]
  }
}
