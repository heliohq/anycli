{
  "name": "outreach",
  "type": "service",
  "description": "Outreach sales engagement as a tool (OAuth 2.0 user token)",
  "auth": {
    "credentials": [
      {
        "source": {"field": "access_token"},
        "inject": {"type": "env", "env_var": "OUTREACH_ACCESS_TOKEN"}
      }
    ]
  }
}
