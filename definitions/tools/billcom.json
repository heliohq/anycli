{
  "name": "billcom",
  "type": "service",
  "description": "BILL (Bill.com) AP/AR: bills, vendors, invoices, customers, payments (read-only), and session/org lookups",
  "auth": {
    "credentials": [
      {
        "source": {
          "field": "dev_key"
        },
        "inject": {
          "type": "env",
          "env_var": "BILLCOM_DEV_KEY"
        }
      },
      {
        "source": {
          "field": "username"
        },
        "inject": {
          "type": "env",
          "env_var": "BILLCOM_USERNAME"
        }
      },
      {
        "source": {
          "field": "password"
        },
        "inject": {
          "type": "env",
          "env_var": "BILLCOM_PASSWORD"
        }
      },
      {
        "source": {
          "field": "organization_id"
        },
        "inject": {
          "type": "env",
          "env_var": "BILLCOM_ORG_ID"
        }
      },
      {
        "source": {
          "field": "auth_mode"
        },
        "inject": {
          "type": "env",
          "env_var": "BILLCOM_AUTH_MODE"
        }
      },
      {
        "source": {
          "field": "env"
        },
        "inject": {
          "type": "env",
          "env_var": "BILLCOM_ENV"
        }
      }
    ]
  }
}
