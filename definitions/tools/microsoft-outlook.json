{
  "name": "microsoft-outlook",
  "type": "service",
  "description": "Microsoft Outlook mail as a tool (user access token)",
  "auth": {
    "credentials": [
      {
        "source": {"field": "access_token"},
        "inject": {"type": "env", "env_var": "MICROSOFT_OUTLOOK_ACCESS_TOKEN"}
      }
    ]
  }
}
