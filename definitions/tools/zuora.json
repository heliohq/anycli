{
  "name": "zuora",
  "type": "service",
  "description": "Zuora Billing as a tool — accounts, subscriptions, invoices, payments, product catalog, and ZOQL queries (OAuth 2.0 client-credentials)",
  "auth": {
    "credentials": [
      {
        "source": {"field": "base_url"},
        "inject": {"type": "env", "env_var": "ZUORA_BASE_URL"}
      },
      {
        "source": {"field": "client_id"},
        "inject": {"type": "env", "env_var": "ZUORA_CLIENT_ID"}
      },
      {
        "source": {"field": "api_secret"},
        "inject": {"type": "env", "env_var": "ZUORA_CLIENT_SECRET"}
      }
    ]
  }
}
